{
  "name": "flashcards",
  "private": true,
  "version": "0.1.0",
  "description": "Mobile-first flashcards app for language learning with spaced repetition.",
  "scripts": {
    "docs:lint": "markdownlint \"docs/**/*.md\"",
    "api:dev": "pnpm --filter @flashcards/api start:dev",
    "api:build": "pnpm --filter @flashcards/api build",
    "api:prisma:validate": "pnpm --filter @flashcards/api exec prisma validate",
    "api:prisma:generate": "pnpm --filter @flashcards/api exec prisma generate",
    "lint": "eslint \"apps/**/*.{ts,tsx,js,jsx}\" --ignore-pattern \"**/dist/**\" --ignore-pattern \"**/node_modules/**\"",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "pnpm api:build",
    "test": "pnpm -r test"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "markdownlint-cli": "^0.49.0",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.1"
  }
}
